@page "/chef/generate"

<div class="mb-4">
    <h1>🤖 ИИ-генератор блюд</h1>
    <p class="text-muted">Создавайте уникальные блюда с помощью искусственного интеллекта</p>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0">📝 Параметры генерации</h5>
            </div>
            <div class="card-body">

                <div class="mb-3">
                    <label class="form-label">Тип блюда</label>
                    <select class="form-select" @bind="request.MealType">
                        <option value="Breakfast">🍳 Завтрак</option>
                        <option value="Lunch">🍲 Обед</option>
                        <option value="Dinner">🍝 Ужин</option>
                        <option value="Dessert">🍰 Десерт</option>
                        <option value="Drink">🥤 Напиток</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Кухня</label>
                    <input type="text"
                           class="form-control"
                           @bind="request.Cuisine"
                           placeholder="Русская, итальянская, авторская..." />
                </div>

                <div class="mb-3">
                    <label class="form-label">Сезон</label>
                    <select class="form-select" @bind="request.Season">
                        <option value="all">Всесезонное</option>
                        <option value="summer">☀️ Лето</option>
                        <option value="winter">❄️ Зима</option>
                        <option value="spring">🌸 Весна</option>
                        <option value="autumn">🍂 Осень</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        💰 Цена блюда:
                        <strong>@request.MinPrice ₽</strong> — <strong>@request.MaxPrice ₽</strong>
                    </label>

                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted small">от</span>
                        <input type="range"
                               class="form-range"
                               min="350"
                               max="5000"
                               step="50"
                               @bind="request.MinPrice" 
                               @bind:event="oninput" 
                               @onchange="ValidatePriceRange" />
                    </div>

                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted small">до</span>
                        <input type="range"
                               class="form-range"
                               min="350"
                               max="5000"
                               step="50"
                               @bind="request.MaxPrice"
                               @bind:event="oninput" 
                               @onchange="ValidatePriceRange" />
                    </div>

                    <div class="price-range-bar mt-2">
                        <div class="price-range-fill"
                             style="left: @((request.MinPrice - 350) * 100 / 4900)%;
                                    right: @(350 - (request.MaxPrice - 100) * 100 / 4900)%;">
                        </div>
                    </div>
                    <div class="d-flex justify-content-between text-muted small">
                        <span>350 ₽</span>
                        <span>5000 ₽</span>
                    </div>

                    <div class="d-flex gap-1 mt-2">
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary"
                                @onclick="() => { request.MinPrice = 100; request.MaxPrice = 500; }">
                            💸 Бюджетное
                        </button>
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary"
                                @onclick="() => { request.MinPrice = 500; request.MaxPrice = 1500; }">
                            💰 Среднее
                        </button>
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary"
                                @onclick="() => { request.MinPrice = 1500; request.MaxPrice = 5000; }">
                            👑 Премиум
                        </button>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Особые требования</label>
                    <textarea class="form-control"
                              @bind="request.SpecialRequirements"
                              rows="3"
                              placeholder="Без глютена, веганское, острое..."></textarea>
                </div>

                <button class="btn btn-primary w-100"
                        @onclick="GenerateDish"
                        disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>🤖 ИИ думает...</span>
                    }
                    else
                    {
                        <span>✨ Сгенерировать блюдо</span>
                    }
                </button>
            </div>
        </div>

        <div class="card mt-3 shadow-sm">
            <div class="card-body">
                <h6>💡 Примеры запросов:</h6>
                <ul class="small text-muted mb-0">
                    <li>"Летний завтрак, русская кухня, бюджетно"</li>
                    <li>"Десерт без сахара, итальянский стиль, премиум"</li>
                    <li>"Острое блюдо для ужина, азиатская кухня"</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        @if (isLoading)
        {
            <div class="text-center mt-5">
                <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;"></div>
                <h4 class="mt-3">🤖 ИИ создаёт блюдо...</h4>
                <p class="text-muted">Анализирую сезонные продукты, подбираю ингредиенты, рассчитываю стоимость</p>
            </div>
        }
        else if (generatedDish != null)
        {
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">🍽️ Результат генерации</h5>
                    <span class="badge bg-info">🤖 ИИ</span>
                </div>
                <div class="card-body">

                    <h4 class="text-primary mb-3">@generatedDish.Name</h4>
                    <h6>📝 Описание</h6>
                    <p>@generatedDish.Description</p>
                    <h6>👨‍🍳 Рецепт</h6>
                    <p style="white-space: pre-line;">@generatedDish.Recipe</p>
                    <h6>🥘 Ингредиенты</h6>
                    <div class="mb-3">
                        @foreach (var ingredient in generatedDish.Ingredients)
                        {
                            <span class="badge bg-light text-dark me-1 mb-1 p-2">@ingredient</span>
                        }
                    </div>
                    @if (generatedDish.Allergens.Any())
                    {
                        <h6>⚠️ Аллергены</h6>
                        <div class="mb-3">
                            @foreach (var allergen in generatedDish.Allergens)
                            {
                                <span class="badge bg-warning text-dark me-1">@allergen</span>
                            }
                        </div>
                    }
                    <div class="row mt-3">
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body text-center py-3">
                                    <h5 class="text-success mb-0">@generatedDish.Price ₽</h5>
                                    <small class="text-muted">Цена</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body text-center py-3">
                                    <h5 class="mb-0">@generatedDish.CookingTimeMinutes</h5>
                                    <small class="text-muted">Минут</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body text-center py-3">
                                    <h5 class="mb-0">@generatedDish.Calories</h5>
                                    <small class="text-muted">Ккал</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body text-center py-3">
                                    <h5 class="mb-0">@generatedDish.Difficulty</h5>
                                    <small class="text-muted">Сложность</small>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                <div class="card-footer d-flex gap-2">
                    <button class="btn btn-success" @onclick="SaveDish">
                        💾 Сохранить и отправить на модерацию
                    </button>
                    <button class="btn btn-outline-primary" @onclick="GenerateDish">
                        🔄 Сгенерировать ещё
                    </button>
                </div>
            </div>
            @if (saveMessage != null)
            {
                <div class="alert alert-success mt-3 d-flex align-items-center">
                    <span class="me-2">✅</span>
                    <span>@saveMessage</span>
                </div>
            }
        }
        else
        {
            <div class="text-center mt-5">
                <div style="font-size: 5rem;">🤖</div>
                <h4 class="text-muted">Здесь появится результат генерации</h4>
                <p>Заполните параметры слева и нажмите "Сгенерировать блюдо"</p>
            </div>
        }

    </div>
</div>