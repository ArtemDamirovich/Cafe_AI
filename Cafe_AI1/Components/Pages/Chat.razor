@page "/chat"
@implements IAsyncDisposable

@* Экран входа *@
@if (string.IsNullOrEmpty(userName))
{
    <div class="row justify-content-center mt-5">
        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-body text-center">
                    <h4>💬 Вход в чат</h4>
                    <input type="text" class="form-control my-3" @bind="nameInput"
                           placeholder="Ваше имя..." />
                    <button class="btn btn-primary w-100" @onclick="JoinChat">
                        Войти в чат
                    </button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    @* Основной интерфейс чата *@
    <div class="row" style="height: 70vh;">

        <div class="col-md-3 border-end">
            <div class="p-3">
                <h5>👥 Сотрудники</h5>

                <div class="mb-2 p-2 @(chatMode == "general" ? "bg-primary text-white rounded" : "")"
                     @onclick="SwitchToGeneral" style="cursor: pointer;">
                    💬 Общий чат
                </div>

                <div class="border-bottom p-3 d-flex justify-content-between">
                    <div>
                        @if (chatMode == "general")
                        {
                            <h5>💬 Общий чат</h5>
                        }
                        else if (selectedUser != null)
                        {
                            <h5>@selectedUser.Name</h5>
                        }
                    </div>
                    @* ✅ Кнопка перехода к ИИ-ассистенту *@
                    <a href="/ai-chat" class="btn btn-outline-info btn-sm">🤖 ИИ-ассистент</a>
                </div>

                <hr />

                @foreach (var user in onlineUsers.Where(u => u.ConnectionId != currentConnectionId))
                {
                    <div class="mb-2 p-2 @(chatMode == "private" && selectedUser?.ConnectionId == user.ConnectionId ? "bg-light rounded" : "")"
                         @onclick="() => SelectPrivateChat(user)" style="cursor: pointer;">
                        @(user.IsOnline ? "🟢" : "⚫") @user.Name
                        <br /><small class="text-muted">@user.Role</small>
                    </div>
                }

                @* ✅ Уведомление здесь — внутри интерфейса чата *@
                @if (notificationMessage != null)
                {
                    <div class="alert alert-info mt-2">@notificationMessage</div>
                }
            </div>
        </div>

        <div class="col-md-9 d-flex flex-column">

            <div class="border-bottom p-3">
                @if (chatMode == "general")
                {
                    <h5>💬 Общий чат</h5>
                }
                else if (selectedUser != null)
                {
                    <h5>@selectedUser.Name</h5>
                    <small>@selectedUser.Role</small>
                }
            </div>

            <div class="flex-grow-1 overflow-auto p-3">
                @foreach (var msg in currentMessages)
                {
                    var isMe = msg.SenderName == userName;
                    <div class="mb-2 d-flex @(isMe ? "justify-content-end" : "")">
                        <div class="p-2 rounded @(isMe ? "bg-primary text-white" : "bg-light")" style="max-width: 70%;">
                            @if (!isMe)
                            {
                                <small class="text-muted d-block">@msg.SenderName</small>
                            }
                            @msg.Content
                            <small class="d-block @(isMe ? "text-white-50" : "text-muted")">@msg.SentAt.ToString("HH:mm")</small>
                        </div>
                    </div>
                }
            </div>

            <div class="border-top p-3">
                <div class="input-group">
                    <input type="text" class="form-control" @bind="newMessage" placeholder="Сообщение..." />
                    <button class="btn btn-primary" @onclick="SendMessage">📤</button>
                </div>
            </div>

        </div>
    </div>
}