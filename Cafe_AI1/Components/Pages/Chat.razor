@page "/chat"
@implements IAsyncDisposable

<div class="row" style="height: 70vh;">

    @* Боковая панель — сотрудники *@
    <div class="col-md-3 border-end">
        <div class="p-3">
            <h5>👥 Сотрудники</h5>
            @foreach (var user in onlineUsers)
            {
                <div class="d-flex align-items-center mb-2 @(selectedUser == user ? "bg-light rounded p-2" : "p-2")"
                     @onclick="() => selectedUser = user" style="cursor: pointer;">
                    <span class="me-2">@(user.IsOnline ? "🟢" : "⚫")</span>
                    <div>
                        <strong>@user.Name</strong><br />
                        <small class="text-muted">@user.Role</small>
                    </div>
                </div>
            }
        </div>
    </div>

    @* Основная область чата *@
    <div class="col-md-9 d-flex flex-column">

        @* Заголовок *@
        <div class="border-bottom p-3 d-flex justify-content-between align-items-center">
            <div>
                @if (isAiChat)
                {
                    <h5 class="mb-0">🤖 ИИ-ассистент</h5>
                }
                else if (selectedUser != null)
                {
                    <h5 class="mb-0">@selectedUser.Name</h5>
                    <small class="text-muted">@selectedUser.Role</small>
                }
                else
                {
                    <h5 class="mb-0">💬 Общий чат</h5>
                }
            </div>
            <div class="d-flex gap-2">
                <button class="btn @(!isAiChat ? "btn-primary" : "btn-outline-primary") btn-sm"
                        @onclick="SwitchToPeopleChat">
                    👥 Люди
                </button>
                <button class="btn @(isAiChat ? "btn-primary" : "btn-outline-primary") btn-sm"
                        @onclick="SwitchToAiChat">
                    🤖 ИИ
                </button>
            </div>
        </div>

        @* Сообщения *@
        <div class="flex-grow-1 overflow-auto p-3">
            @foreach (var msg in messages)
            {
                var isMe = msg.SenderName == userName;
                <div class="mb-2 d-flex @(isMe ? "justify-content-end" : "")">
                    <div class="p-2 rounded @(isMe ? "bg-primary text-white" : "bg-light")" style="max-width: 70%;">
                        @if (!isMe)
                        {
                            <small class="text-muted d-block">@msg.SenderName</small>
                        }
                        @msg.Content
                        <small class="d-block @(isMe ? "text-white-50" : "text-muted")">
                            @msg.SentAt.ToString("HH:mm")
                        </small>
                    </div>
                </div>
            }
        </div>

        @* Поле ввода *@
        <div class="border-top p-3">
            <div class="input-group">
                <input type="text" class="form-control" @bind="newMessage"
                       placeholder="Введите сообщение..." />
                <button class="btn btn-primary" @onclick="SendMessage">📤</button>
            </div>
        </div>

    </div>
</div>